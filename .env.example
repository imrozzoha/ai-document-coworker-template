# AI Provider — set to: mock | openai | claude
# Defaults to "mock" if not set (no API key required)
AI_PROVIDER=mock

# OpenAI (required when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Copy this file to .env.local and fill in values — never commit .env.local
